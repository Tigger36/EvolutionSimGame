# Copy to `.cursor/worker.env` and adjust for your machine.
# `.cursor/worker.env` is gitignored — do not commit secrets.
#
# First-time setup:
#   1. cp .cursor/worker.env.example .cursor/worker.env
#   2. agent login   # recommended for personal My Machines workers
#      OR set CURSOR_API_KEY below (personal/user key for My Machines;
#      service-account key required only when CURSOR_WORKER_POOL=true)
#   3. ./scripts/start-self-hosted-worker.sh debug
#   4. ./scripts/start-self-hosted-worker.sh
#
# In Cursor: Cloud Agents → environment dropdown → pick the worker name below.

# Display name shown in the Cloud Agents dashboard and for worker=/machine= triggers.
CURSOR_WORKER_NAME=evolutionsimgame-mac

# My Machines (default): leave CURSOR_WORKER_POOL unset or false.
# Enterprise pool: set to true and use a service-account API key.
# CURSOR_WORKER_POOL=false
# CURSOR_WORKER_POOL_NAME=default

# Optional: personal or service-account API key (otherwise use `agent login`).
# CURSOR_API_KEY=

# Optional: verbose startup logs (shows registered repo labels and workspace paths).
CURSOR_WORKER_VERBOSE=true

# Optional: expose /healthz, /readyz, and /metrics (e.g. 127.0.0.1:8080).
# CURSOR_WORKER_MANAGEMENT_ADDR=127.0.0.1:8080

# Pool-only: seconds to stay connected after a session ends (0 = disabled).
# CURSOR_WORKER_IDLE_RELEASE_TIMEOUT=600

# Optional: override worker data directory (logs, artifacts).
# CURSOR_DATA_DIR=$HOME/.local/share/cursor-agent/evolutionsimgame
